# Copy to .env and fill in values.
# --- Folders ---
INPUT_FOLDER=licenses/
OUTPUT_FOLDER=results/

# --- Ollama ---
# OLLAMA_URL is set automatically based on the runtime environment:
#   Plain Python (venv) → http://localhost:11434/api/chat
#   Docker Compose      → http://host.docker.internal:11434/api/chat
#
# You only need to set this if you want to override the auto-detection,
# for example to point at a remote Ollama instance.
#
# OLLAMA_URL=http://localhost:11434/api/chat

OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=60

# --- OCR ---
# Set to true if you have an NVIDIA GPU + NVIDIA Container Toolkit installed
USE_GPU=false
EOF